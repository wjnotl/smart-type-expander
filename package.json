{
  "name": "smart-type-expander",
  "version": "1.0.0",
  "description": "A CLI tool to recursively expand complex nested TypeScript types while protecting native objects, third-party classes, and ORM enums.",
  "main": "dist/bin/cli.js",
  "bin": {
    "smart-type-expander": "./dist/bin/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "release": "standard-version",
    "postrelease": "git push --follow-tags origin main",
    "format": "prettier --write \"**/*.{ts,js}\""
  },
  "dependencies": {
    "typescript": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.8.3",
    "standard-version": "^9.5.0"
  },
  "keywords": [
    "typescript",
    "cli",
    "type-expander",
    "compiler-api",
    "zod",
    "prisma",
    "decimal"
  ],
  "author": "",
  "license": "MIT"
}
